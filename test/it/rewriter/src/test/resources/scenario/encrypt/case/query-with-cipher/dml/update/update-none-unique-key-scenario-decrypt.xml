<rewrite-assertions yaml-rule="scenario/encrypt/config/none-unique-key-scenario-decrypt.yaml">
    <rewrite-assertion id="update_for_decrypt" db-types="MySQL">
        <input sql="/* SHARDINGSPHERE_HINT: NONE_UNIQUE_KEY_SCENARIO=DECRYPT */ update t_config set username = ? where username = ?" parameters="zhangsan, zhangsan" />
        <output sql="update `encrypt_ds`.t_config set plain_username = ? where cipher_username = ? and plain_username is null" parameters="zhangsan, encrypt_zhangsan" />
    </rewrite-assertion>
    <rewrite-assertion id="update_for_decrypt" db-types="MySQL">
        <input sql="/* SHARDINGSPHERE_HINT: NONE_UNIQUE_KEY_SCENARIO=DECRYPT */ update `t_config` set `username` = ? where `username` = ?" parameters="zhangsan, zhangsan" />
        <output sql="update `encrypt_ds`.`t_config` set `plain_username` = ? where `cipher_username` = ? and `plain_username` is null" parameters="zhangsan, encrypt_zhangsan" />
    </rewrite-assertion>
</rewrite-assertions>
