<e2e-test-cases>
    <test-case sql="CREATE VIEW t_order_sharding_view AS SELECT o.* FROM t_order o INNER JOIN t_order_item i ON o.order_id = i.order_id" scenario-types="db,tbl" db-types="MySQL">
        <assertion expected-data-file="create_view_with_sharding_table.xml">
            <initial-sql affected-table="t_order_sharding_view" />
            <destroy-sql sql="DROP VIEW t_order_sharding_view" />
        </assertion>
    </test-case>

    <!-- SPEX ADDED: BEGIN -->
    <test-case sql="CREATE VIEW t_user_view AS SELECT * FROM t_user" scenario-types="encrypt" db-types="MySQL,PostgreSQL,openGauss,DM">
        <assertion expected-data-file="create_view.xml">
            <initial-sql affected-table="t_user_view" />
            <destroy-sql sql="DROP VIEW t_user_view" />
        </assertion>
    </test-case>

    <test-case sql="CREATE VIEW t_user_view AS SELECT * FROM t_user WHERE user_name = 'jack'" scenario-types="encrypt" db-types="MySQL,PostgreSQL,openGauss,DM">
        <assertion expected-data-file="create_view.xml">
            <initial-sql affected-table="t_user_view" />
            <destroy-sql sql="DROP VIEW t_user_view" />
        </assertion>
    </test-case>

    <test-case sql="CREATE VIEW t_user_view AS SELECT user_name, COUNT(1) AS count FROM t_user WHERE user_name = 'jack' GROUP BY user_name ORDER BY user_name" scenario-types="encrypt" db-types="MySQL">
        <assertion expected-data-file="create_view_with_group_by_order_by.xml">
            <initial-sql affected-table="t_user_view" />
            <destroy-sql sql="DROP VIEW t_user_view" />
        </assertion>
    </test-case>

    <test-case sql="CREATE OR REPLACE VIEW t_user_view AS SELECT * FROM t_user" scenario-types="encrypt" db-types="MySQL,PostgreSQL,openGauss,DM">
        <assertion expected-data-file="create_view.xml">
            <initial-sql sql="CREATE VIEW t_user_view AS SELECT * FROM t_user" affected-table="t_user_view" />
            <destroy-sql sql="DROP VIEW t_user_view" />
        </assertion>
    </test-case>
    <!-- SPEX ADDED: END -->
</e2e-test-cases>
