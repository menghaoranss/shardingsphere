<e2e-test-cases>
    <test-case sql="CREATE TABLE t_order_details(id int, description varchar(10))" scenario-types="db,tbl,dbtbl_with_readwrite_splitting,readwrite_splitting">
        <assertion expected-data-file="create_table.xml">
            <initial-sql affected-table="t_order_details" />
            <destroy-sql sql="DROP TABLE t_order_details" />
        </assertion>
    </test-case>
    
    <test-case sql="CREATE TABLE t_broadcast_table_for_ddl(id int, description varchar(10))" scenario-types="db,tbl,dbtbl_with_readwrite_splitting,readwrite_splitting">
        <assertion expected-data-file="create_broadcast_table.xml">
            <initial-sql affected-table="t_broadcast_table_for_ddl" />
            <destroy-sql sql="DROP TABLE t_broadcast_table_for_ddl" />
        </assertion>
    </test-case>
    
    <test-case sql="CREATE TABLE t_user_details (user_id INT NOT NULL, address_id INT NOT NULL, number VARCHAR(45), description varchar(10))" scenario-types="encrypt,dbtbl_with_readwrite_splitting_and_encrypt,sharding_and_encrypt,encrypt_and_readwrite_splitting" db-types="MySQL,PostgreSQL,openGauss">
        <assertion expected-data-file="create_table.xml">
            <initial-sql affected-table="t_user_details" />
            <destroy-sql sql="DROP TABLE t_user_details" />
        </assertion>
    </test-case>
    
    <!-- SPEX ADDED: BEGIN -->
    <test-case sql="CREATE TABLE t_product (product_id INT, product_name VARCHAR(200), category_id INT, price DECIMAL, status VARCHAR(20), creation_date DATE)" db-types="MySQL,TiDB" scenario-types="sphereex_encrypt_data_type">
        <assertion expected-data-file="create_table_with_data_type.xml">
            <initial-sql affected-table="t_product" />
            <destroy-sql sql="DROP TABLE t_product" />
        </assertion>
    </test-case>
    
    <test-case sql="CREATE TABLE t_user_details (user_id INT NOT NULL, address_id INT, number VARCHAR(45), description varchar(16079))" db-types="MySQL" scenario-types="encrypt" scenario-comments="MySQL utf8mb4 expansion rate calculation and all column maximum length test">
        <assertion expected-data-file="create_table.xml">
            <initial-sql affected-table="t_user_details" />
            <destroy-sql sql="DROP TABLE t_user_details" />
        </assertion>
    </test-case>
    
    <test-case sql="CREATE TABLE t_user_details (user_id INT NOT NULL, description varchar(16382))" db-types="MySQL" scenario-types="encrypt" scenario-comments="MySQL utf8mb4 single column maximum length test">
        <assertion expected-data-file="create_user_detail_table_part_columns.xml">
            <initial-sql affected-table="t_user_details" />
            <destroy-sql sql="DROP TABLE t_user_details" />
        </assertion>
    </test-case>
    
    <test-case sql="CREATE TABLE t_user_details (user_id INT NOT NULL, description varchar(65528)) DEFAULT CHARSET=latin1" db-types="MySQL" scenario-types="encrypt" scenario-comments="MySQL latin1 single column maximum length test">
        <assertion expected-data-file="create_user_detail_table_part_columns.xml">
            <initial-sql affected-table="t_user_details" />
            <destroy-sql sql="DROP TABLE t_user_details" />
        </assertion>
    </test-case>
    
    <test-case sql="CREATE TABLE t_user_details (user_id INT NOT NULL, address_id INT, number VARCHAR(45), description varchar(65413)) DEFAULT CHARSET=latin1" db-types="MySQL" scenario-types="encrypt" scenario-comments="MySQL latin1 expansion rate calculation and all column maximum length test">
        <assertion expected-data-file="create_table.xml">
            <initial-sql affected-table="t_user_details" />
            <destroy-sql sql="DROP TABLE t_user_details" />
        </assertion>
    </test-case>
    <!-- SPEX ADDED: END -->
</e2e-test-cases>
