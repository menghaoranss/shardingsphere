<!-- SPEX ADDED: BEGIN -->
<e2e-test-cases>
    <!-- MySQL union with encrypt column from same table -->
    <test-case sql="SELECT * FROM t_user UNION SELECT * FROM t_user" db-types="MySQL" scenario-types="encrypt">
        <assertion expected-data-source-name="read_dataset" />
    </test-case>
    
    <!-- MySQL union with encrypt column from same table and order by limit -->
    <test-case sql="SELECT * FROM t_user UNION ALL SELECT * FROM t_user ORDER BY user_id LIMIT 5, 5" db-types="MySQL" scenario-types="encrypt">
        <assertion expected-data-source-name="read_dataset" />
    </test-case>
    
    <!-- MySQL union with encrypt column from same table and predicate, order by limit -->
    <test-case sql="SELECT * FROM t_user WHERE user_id > ? UNION SELECT * FROM t_user WHERE user_id = ? ORDER BY user_id LIMIT 5, 5" db-types="MySQL" scenario-types="encrypt">
        <assertion parameters="10:int, 10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <!-- MySQL union with same encryptor encrypt column from different table -->
    <test-case sql="SELECT user_name, password FROM t_user UNION SELECT telephone, business_code FROM t_merchant" db-types="MySQL" scenario-types="encrypt">
        <assertion expected-data-source-name="read_dataset" />
    </test-case>
</e2e-test-cases>
<!-- SPEX ADDED: END -->
