<e2e-test-cases>
    <!-- MySQL projection subquery -->
    <test-case sql="SELECT u.user_id, (SELECT user_name FROM t_user LIMIT 1) FROM t_user u WHERE u.user_id = ?" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <test-case sql="SELECT u.user_id, (SELECT user_name FROM t_user LIMIT 1) AS `user_name` FROM t_user u WHERE u.user_id = ?" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <!-- MySQL predicate subquery -->
    <test-case sql="SELECT u.* FROM t_user u WHERE u.user_name = (SELECT user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>

    <test-case sql="SELECT u.* FROM t_user u WHERE u.telephone = (SELECT DISTINCT telephone FROM t_merchant WHERE telephone = ?)" scenario-types="encrypt" db-types="MySQL,PostgreSQL,openGauss,Oracle,DM">
        <assertion parameters="86100000001:String" expected-data-source-name="read_dataset" />
    </test-case>

    <test-case sql="SELECT * FROM t_user WHERE telephone = (SELECT DISTINCT telephone FROM t_merchant WHERE telephone = ?)" scenario-types="encrypt" db-types="MySQL,PostgreSQL,openGauss,Oracle,DM">
        <assertion parameters="86100000001:String" expected-data-source-name="read_dataset" />
    </test-case>
    
    <test-case sql="SELECT u.* FROM t_user u WHERE u.user_name = ANY (SELECT user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <test-case sql="SELECT u.* FROM t_user u WHERE u.user_name IN (SELECT user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <test-case sql="SELECT u.* FROM t_user u WHERE u.user_name != ALL (SELECT user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <!-- FIXME support mysql row subquery -->
    <!--<test-case sql="SELECT u.* FROM t_user u WHERE (u.user_id, u.user_name) = (SELECT user_id, user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>-->
    
    <!-- FIXME support mysql row subquery -->
    <!--<test-case sql="SELECT u.* FROM t_user u WHERE ROW(u.user_id, u.user_name) = (SELECT user_id, user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>-->
    
    <test-case sql="SELECT u.* FROM t_user u WHERE EXISTS (SELECT user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <test-case sql="SELECT u.* FROM t_user u WHERE NOT EXISTS (SELECT user_name FROM t_user WHERE user_id = ?)" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <test-case sql="SELECT u.* FROM t_user u WHERE u.user_name = ANY (SELECT user_name FROM t_user u2 WHERE u.user_id = u2.user_id)" scenario-types="encrypt" db-types="MySQL">
        <assertion expected-data-source-name="read_dataset" />
    </test-case>
    
    <test-case sql="SELECT * FROM (SELECT * FROM t_user) AS temp WHERE user_id = ?" scenario-types="encrypt" db-types="MySQL">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
