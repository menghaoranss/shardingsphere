<e2e-test-cases>
    <!-- OPE 适配 SQL 场景参考：https://u01f1kqxrl.feishu.cn/wiki/VCinwK3y1iwG74kaitBc4ot0n1f -->
    <!-- 测试字符串类型 GROUP BY, HAVING -->
    <test-case sql="SELECT user_name, COUNT(1) FROM t_user GROUP BY user_name ORDER BY user_name" db-types="MySQL,PostgreSQL,openGauss,KingbaseES,DM,Oracle,OceanBase_Oracle,TiDB" scenario-types="sphereex_encrypt_ope">
        <assertion expected-data-source-name="read_dataset" />
    </test-case>

    <test-case sql="SELECT user_name, COUNT(1) FROM t_user GROUP BY user_name HAVING user_name IN (?, ?) ORDER BY user_name" db-types="MySQL,PostgreSQL,openGauss,KingbaseES,DM,Oracle,OceanBase_Oracle,TiDB" scenario-types="sphereex_encrypt_ope">
        <assertion parameters="zhuqi:String, 张翼:String" expected-data-source-name="read_dataset" />
    </test-case>

    <test-case sql="SELECT user_name, COUNT(1) FROM t_user GROUP BY user_name HAVING user_name = ?" db-types="MySQL,PostgreSQL,openGauss,KingbaseES,DM,Oracle,OceanBase_Oracle,TiDB" scenario-types="sphereex_encrypt_ope">
        <assertion parameters="zhuqi:String"  expected-data-source-name="read_dataset" />
    </test-case>

    <test-case sql="SELECT user_name, COUNT(1) FROM t_user GROUP BY user_name HAVING user_name &lt; ? ORDER BY user_name" db-types="MySQL,PostgreSQL,openGauss,KingbaseES,DM,Oracle,OceanBase_Oracle,TiDB" scenario-types="sphereex_encrypt_ope">
        <assertion parameters="zhuqi:String"  expected-data-source-name="read_dataset" />
    </test-case>

    <test-case sql="SELECT user_name, COUNT(1) FROM t_user GROUP BY user_name HAVING user_name BETWEEN ? AND ? ORDER BY user_name" db-types="MySQL,PostgreSQL,openGauss,KingbaseES,DM,Oracle,OceanBase_Oracle,TiDB" scenario-types="sphereex_encrypt_ope">
        <assertion parameters="zhuqi:String, 张翼:String" expected-data-source-name="read_dataset" />
