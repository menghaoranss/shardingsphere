<e2e-test-cases>
    <!-- fixme dm 改写为加上 db_0 -->
    <!-- test sharding table and single table cross database join -->
    <test-case sql="SELECT * FROM t_order o INNER JOIN t_user u ON o.user_id = u.user_id WHERE u.user_id = 10" db-types="MySQL" scenario-types="db,dbtbl_with_readwrite_splitting">
        <assertion expected-data-source-name="read_dataset" />
    </test-case>
    
    <!-- fixme dm 改写为加上 db_0 -->
    <!-- test single table and single table cross database join -->
    <test-case sql="SELECT * FROM t_product p INNER JOIN t_product_detail pd ON p.product_id = pd.product_id WHERE p.product_id = ?" db-types="MySQL" scenario-types="db,dbtbl_with_readwrite_splitting">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
    
    <!-- fixme dm 改写为加上 db_0 -->
    <!-- test broadcast table and single table cross database join -->
    <test-case sql="SELECT * FROM t_product p LEFT JOIN t_product_category c ON p.category_id = c.category_id WHERE c.category_id = ? ORDER BY p.product_id" db-types="MySQL" scenario-types="db,dbtbl_with_readwrite_splitting">
        <assertion parameters="10:int" expected-data-source-name="read_dataset" />
    </test-case>
</e2e-test-cases>
